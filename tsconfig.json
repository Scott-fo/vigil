{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "jsxImportSource": "@opentui/react",
    "allowJs": true,

    // Bundler mode
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "#tui": ["packages/tui/src/index.ts"],
      "#tui/*": ["packages/tui/src/*"],
      "#ui/*": ["packages/tui/src/ui/*"],
      "#data/*": ["packages/tui/src/data/*"],
      "#diff/*": ["packages/tui/src/diff/*"],
      "#theme/*": ["packages/tui/src/theme/*"],
      "#syntax/*": ["packages/tui/src/syntax/*"],
      "#config/*": ["packages/tui/src/config/*"]
    },
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  }
}
