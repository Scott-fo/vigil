{
	"name": "vigil",
	"module": "src/index.tsx",
	"type": "module",
	"private": true,
	"license": "MIT",
	"bin": {
		"vigil": "./bin/vigil"
	},
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"dev": "bun run --watch src/index.tsx",
		"install:global": "bun install && bun link",
		"test": "bun run --filter '*' test",
		"test:watch": "bun run --filter '*' test:watch",
		"typecheck": "tsgo --noEmit -p packages/api/ && tsgo --noEmit -p packages/server/ && tsgo --noEmit -p packages/tui/",
		"prepare": "effect-language-service patch"
	},
	"devDependencies": {
		"@effect/language-service": "^0.77.0",
		"@types/bun": "latest",
		"@types/react": "^19.2.14"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@vigil/server": "workspace:*",
		"@vigil/tui": "workspace:*",
		"effect": "^3.19.19",
		"@effect/workflow": "^0.16.0"
	}
}
